  "routing": {
    "description": "GLM-5 Turbo handles most tasks. Coding routes to Copilot sub-agents. Complex multi-file tasks escalate to Claude Code via ACP.",
    "rules": [
      { "condition": "task requires coding", "model": "github-copilot/claude-opus-4.6" },
