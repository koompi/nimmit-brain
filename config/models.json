      { "condition": "image generation (studio quality)", "model": "google/gemini-3-pro-image-preview" },
      { "condition": "deep research", "model": "google/gemini-3.1-pro" },
      { "condition": "video generation", "model": "google/veo-3.1" },
      { "condition": "default / everything else", "model": "zai/glm-5-turbo" }
