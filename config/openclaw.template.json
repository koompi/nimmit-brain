{
  "meta": {
    "lastTouchedVersion": "2.0.0"
  },
  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/chromium",
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-5-turbo",
        "fallbacks": [
          "github-copilot/gpt-5.3-codex",
          "google/gemini-3.1-pro"
        ]
      },
      "imageModel": {
        "primary": "google/gemini-3.1-flash-lite-preview"
      },
      "memorySearch": {
        "provider": "local"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m",
        "target": "last"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "{{BRAIN_DIR}}",
        "identity": {
          "name": "{{AGENT_NAME}}",
          "emoji": "🦅"
        },
        "subagents": {
          "allowAgents": ["*"]
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "fs": {
      "workspaceOnly": false
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "{{TELEGRAM_TOKEN}}",
      "allowFrom": [],
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "mediaMaxMb": 20
    },
    "discord": {
      "enabled": false,
      "token": "",
      "groupPolicy": "open",
      "streaming": "off",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback"
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    }
  },
  "plugins": {
    "allow": [
      "acpx",
      "lossless-claw",
      "memory-lancedb",
      "telegram"
    ],
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      },
      "lossless-claw": {
        "enabled": true,
        "config": {}
      },
      "memory-lancedb": {
        "enabled": true
      }
    }
  }
}
